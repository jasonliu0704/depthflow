# DepthFlow API runtime configuration

DEPTHFLOW_API_WORKDIR=/opt/depthflow/DepthFlow/.depthflow-api
DEPTHFLOW_API_DEFAULT_OUTPUT_TARGET=local

HOST=0.0.0.0
PORT=8000
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info

# Optional local output target example:
# Output paths passed by API callers can point into:
# /opt/depthflow/DepthFlow/output

# Optional Azure Blob output
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=depthflow-videos
# AZURE_PUBLIC_BASE_URL=https://youraccount.blob.core.windows.net/depthflow-videos

# Optional Azure Speech synthesis for request speech_text
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
# AZURE_SPEECH_VOICE=en-US-FableTurboMultilingualNeural
